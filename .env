# Database Configuration
# Choose: 'sql' for SQL databases (SQLite, PostgreSQL, MySQL)
# Choose: 'mongo' for MongoDB
DB_TYPE=sql

# SQL Database Configuration (if DB_TYPE=sql)
# For SQLite: sqlite:///data/crypto_prediction.db
# For PostgreSQL: postgresql://user:password@localhost/dbname
SQL_CONNECTION_STRING=sqlite:///data/crypto_prediction.db

# MongoDB Configuration (if DB_TYPE=mongo)
MONGO_CONNECTION_STRING=mongodb://localhost:27017/
MONGO_DATABASE=crypto_prediction
